{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "viralrepo-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "viralrepo-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "architecte",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "./Architecte", "start"],
      "port": 3100,
      "autoPort": true
    }
  ]
}

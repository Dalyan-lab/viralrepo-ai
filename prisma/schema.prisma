generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String? // null pour les comptes OAuth (Google/GitHub)
  provider  String   @default("credentials") // credentials | google | github
  role      String   @default("user") // user | admin
  createdAt DateTime @default(now())

  scripts    Script[]
  avatarJobs AvatarJob[]
  resets     PasswordReset[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Script {
  id        String   @id @default(cuid())
  userId    String
  repoName  String
  repoUrl   String
  platform  String // tiktok | reels | shorts | youtube
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarJob {
  id         String   @id @default(cuid())
  userId     String
  scriptText String
  avatarUrl  String // URL de l'image d'avatar (importée ou préréglée)
  status     String   @default("queued") // queued | processing | done | error
  resultUrl  String?
  didTalkId  String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

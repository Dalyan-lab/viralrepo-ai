generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String? // null pour les comptes OAuth (Google/GitHub)
  provider  String   @default("credentials") // credentials | google | github
  role      String   @default("user") // user | admin
  createdAt DateTime @default(now())

  // Abonnement Stripe
  plan                 String  @default("decouverte") // decouverte | createur | studio
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  subscriptionStatus   String? // active | canceled | past_due | ...

  // Parrainage
  referralCode          String? @unique @default(cuid()) // généré à la création ; init paresseuse pour les comptes existants
  referredById          String? // id du parrain
  referralRewards       Int     @default(0) // nombre de filleuls convertis (récompenses gagnées)
  refereeDiscountUsed   Boolean @default(false) // le filleul a déjà utilisé sa réduction de bienvenue
  pendingReferralReward Boolean @default(false) // récompense parrain à appliquer au prochain abonnement

  scripts           Script[]
  avatarJobs        AvatarJob[]
  resets            PasswordReset[]
  referralsMade     Referral[] @relation("Referrer")
  referralReceived  Referral?  @relation("Referee")
}

// Un parrainage : lien parrain → filleul, avec suivi de conversion.
model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  refereeId     String   @unique
  status        String   @default("pending") // pending | converted
  rewardGranted Boolean  @default(false)
  createdAt     DateTime @default(now())
  convertedAt   DateTime?

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Script {
  id        String   @id @default(cuid())
  userId    String
  repoName  String
  repoUrl   String
  platform  String // tiktok | reels | shorts | youtube
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarJob {
  id         String   @id @default(cuid())
  userId     String
  scriptText String
  avatarUrl  String // URL de l'image d'avatar (importée ou préréglée)
  status     String   @default("queued") // queued | processing | done | error
  resultUrl  String?
  didTalkId  String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

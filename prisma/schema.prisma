generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String? // null pour les comptes OAuth (Google/GitHub)
  provider  String   @default("credentials") // credentials | google | github
  role      String   @default("user") // user | admin
  createdAt DateTime @default(now())

  // Abonnement (Paystack — cartes + Mobile Money)
  plan               String    @default("decouverte") // decouverte | createur | studio
  subscriptionStatus String? // active | expired | canceled
  planExpiresAt      DateTime? // fin de l'accès premium (accès à la période payée)
  paystackAuthCode   String? // code d'autorisation Paystack (renouvellement futur)
  paystackCustomer   String? // code client Paystack

  // Parrainage
  referralCode          String? @unique @default(cuid()) // généré à la création ; init paresseuse pour les comptes existants
  referredById          String? // id du parrain
  referralRewards       Int     @default(0) // nombre de filleuls convertis (récompenses gagnées)
  refereeDiscountUsed   Boolean @default(false) // le filleul a déjà utilisé sa réduction de bienvenue
  pendingReferralReward Boolean @default(false) // récompense parrain à appliquer au prochain abonnement

  // Série d'engagement (streak quotidien)
  streak                   Int    @default(0) // jours consécutifs d'activité
  longestStreak            Int    @default(0) // record personnel
  lastActiveDate           String? // dernier jour actif (AAAA-MM-JJ, UTC)
  lastStreakRewardMilestone Int   @default(0) // plus haut palier de série récompensé

  scripts           Script[]
  avatarJobs        AvatarJob[]
  resets            PasswordReset[]
  referralsMade     Referral[] @relation("Referrer")
  referralReceived  Referral?  @relation("Referee")
  activityDays      ActivityDay[]
}

// Un jour d'activité (pour la vue hebdomadaire de la série).
model ActivityDay {
  id     String @id @default(cuid())
  userId String
  date   String // AAAA-MM-JJ (UTC)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Un parrainage : lien parrain → filleul, avec suivi de conversion.
model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  refereeId     String   @unique
  status        String   @default("pending") // pending | converted
  rewardGranted Boolean  @default(false)
  createdAt     DateTime @default(now())
  convertedAt   DateTime?

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Script {
  id        String   @id @default(cuid())
  userId    String
  repoName  String
  repoUrl   String
  platform  String // tiktok | reels | shorts | youtube
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarJob {
  id         String   @id @default(cuid())
  userId     String
  scriptText String
  avatarUrl  String // URL de l'image d'avatar (importée ou préréglée)
  status     String   @default("queued") // queued | processing | done | error
  resultUrl  String?
  didTalkId  String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

# === ViralRepo.AI — modèle de configuration ===
# Copiez ce fichier en .env et remplissez les valeurs.

# --- Base de données ---
# Local (dev) : SQLite → "file:./viralrepo.db"
# Production : PostgreSQL (Neon/Supabase) → "postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./viralrepo.db"

# --- Sécurité des sessions ---
# Générez un secret : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me"

# --- IA Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# --- GitHub API (radar) — https://github.com/settings/tokens ---
GITHUB_TOKEN=""

# --- Connexion Google — https://console.cloud.google.com ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Connexion GitHub — https://github.com/settings/developers ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Emails (https://resend.com/api-keys) ---
RESEND_API_KEY=""
EMAIL_FROM=""

# --- Paiements Paystack (https://dashboard.paystack.com) — cartes + Mobile Money ---
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
# Renouvellement auto des abonnements (Vercel Cron)
CRON_SECRET=""

# --- Replicate : UNE seule clé pour tout (images, vidéo, musique, VOIX OFF,
#     AVATAR lip-sync) — https://replicate.com/account/api-tokens ---
# Suffit à remplacer ElevenLabs (voix) ET D-ID (avatar) ci-dessous.
REPLICATE_API_TOKEN=""
REPLICATE_IMAGE_MODEL="black-forest-labs/flux-schnell"
REPLICATE_VIDEO_MODEL="minimax/video-01"
REPLICATE_MUSIC_MODEL="meta/musicgen"
REPLICATE_TTS_MODEL="minimax/speech-02-hd"
REPLICATE_LIPSYNC_MODEL="cjwbw/sadtalker"

# --- Vidéo IA (Runway) — anime les images des scènes (montage Production) ---
RUNWAY_API_KEY=""

# --- Voix off ElevenLabs (OPTIONNEL — Replicate suffit) — https://elevenlabs.io ---
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# --- Avatar D-ID (OPTIONNEL — Replicate suffit) — https://www.d-id.com ---
DID_API_KEY=""

# --- URL publique de l'app ---
# Local : http://localhost:3000
# Production : https://votre-domaine.vercel.app (SANS slash final)
# Sert aux callbacks OAuth et au webhook D-ID.
APP_URL="http://localhost:3000"
